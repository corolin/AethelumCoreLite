# Gitea PyPI 仓库配置
# 复制此文件为 .env 并填入实际值
# 使用方法: cp .env.example .env

# ==================== 必填配置 ====================

# Gitea PyPI 仓库 URL
# 将 {owner} 替换为你的组织/用户名
# 示例: https://gitea.example.com/api/packages/myorg/pypi
GITEA_PYPI_URL=https://gitea.example.com/api/packages/{owner}/pypi

# Gitea 用户名
GITEA_USERNAME=your-username

# Gitea Token（推荐）或密码
# 如何创建 Token:
# 1. 登录 Gitea
# 2. 设置 → 应用令牌 → 生成新令牌
# 3. 作用域选择: read:package, write:package
GITEA_PASSWORD=your-token-here